{
  "name": "@lancernix/mcp-adapter",
  "version": "1.0.0",
  "description": "标准通用 MCP 延迟路由网关，物理拦截海量工具定义，节省大模型上下文开销",
  "type": "module",
  "bin": {
    "mcp-adapter": "dist/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "start": "node dist/index.js",
    "prepack": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "mcp-server",
    "tools",
    "gateway",
    "lazy-loading"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fuse.js": "^7.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^20.11.0",
    "typescript": "^5.9.3"
  },
  "volta": {
    "node": "24.12.0",
    "pnpm": "10.28.0"
  }
}
